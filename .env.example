# --- Financial Ledger (TigerBeetle) ---
TIGERBEETLE_CLUSTER_ID=
TIGERBEETLE_ADDRESS=

# --- Frontend Configuration ---
VITE_API_URL=

# --- CORS & Logging ---
CORS_ALLOWED_ORIGINS=
LOG_LEVEL=

# --- OpenRouter API KEY ---
OPENROUTER_API_KEY = 